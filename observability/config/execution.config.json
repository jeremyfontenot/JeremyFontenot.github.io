{
  "execution_layer": {
    "enabled": true,
    "strict_mode": true,
    "inline_execution_allowed": false,
    "description": "Hardened execution layer - file-based only, no inline scripts"
  },
  "invocation_rules": {
    "enforce_file_based_execution": true,
    "reject_inline_patterns": [
      "python -c",
      "bash -c",
      "powershell -Command",
      "eval(",
      "exec(",
      "invoke-expression"
    ],
    "allowed_runtimes": [
      "python",
      "pwsh",
      "node"
    ]
  },
  "subprocess_configuration": {
    "isolation_level": "subprocess",
    "shell_execution": false,
    "inherit_environment": false,
    "timeout_default_seconds": 300,
    "timeout_min_seconds": 10,
    "timeout_max_seconds": 3600,
    "capture_stderr": true,
    "capture_stdout": false
  },
  "output_contract": {
    "validation_enabled": true,
    "schema_validation_strict": true,
    "allowed_output_formats": [
      "json",
      "jsonl",
      "log"
    ],
    "required_metadata": [
      "timestamp",
      "execution_status",
      "exit_code"
    ]
  },
  "failure_handling": {
    "non_zero_exit_action": "CREATE_SYSTEM_INCIDENT",
    "missing_output_action": "CREATE_SYSTEM_INCIDENT",
    "schema_validation_failure_action": "CREATE_SYSTEM_INCIDENT",
    "timeout_action": "CREATE_SYSTEM_INCIDENT",
    "fallback_execution_allowed": false,
    "auto_retry_enabled": false
  },
  "monitoring": {
    "log_all_invocations": true,
    "log_level": "INFO",
    "emit_metrics": true,
    "metrics_destination": "observability/reports/execution_metrics.json"
  },
  "incident_classification": {
    "auto_classify": true,
    "send_to_system_incidents": true,
    "send_to_seo_incidents": false,
    "create_github_issue": false
  },
  "guardrails": {
    "max_concurrent_scripts": 5,
    "max_script_size_mb": 10,
    "forbid_absolute_paths": false
  }
}
