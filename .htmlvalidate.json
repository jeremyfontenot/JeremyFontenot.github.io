{
  "extends": ["html-validate:recommended"],
  "ignore": [
    "sorted-documents/**",
    "legacy-site-backup/**",
    "proof-staging/**"
  ]
}{
  "extends": ["html-validate:recommended"],
  "rules": {
    "attr-quotes": "off",
    "doctype-style": "off",
    "no-raw-characters": "off",
    "no-trailing-whitespace": "off",
    "void-style": "off"
  }
}
